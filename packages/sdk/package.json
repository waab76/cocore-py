{
  "name": "@cocore/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "co/core TypeScript SDK: lexicon types, canonical-JSON, validators, and helpers shared across appview, exchange, and console.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./canonical": "./src/canonical.ts",
    "./firehose": "./src/firehose.ts",
    "./lex": "./src/lex-runtime.ts",
    "./mda": "./src/mda.ts",
    "./multimodal-envelope": "./src/multimodal-envelope.ts",
    "./appattest": "./src/appattest.ts",
    "./brokerage": "./src/brokerage.ts",
    "./verify-provider": "./src/verify-provider.ts",
    "./oauth-scope": "./src/oauth-scope.ts",
    "./p256": "./src/p256.ts",
    "./provider-selection": "./src/provider-selection.ts",
    "./publish": "./src/publish.ts",
    "./resolve": "./src/resolve.ts",
    "./types": "./src/types.ts",
    "./validate": "./src/validate.ts"
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "vitest run",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@atcute/oauth-types": "^0.1.1",
    "@atproto/lexicon": "^0.5.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
